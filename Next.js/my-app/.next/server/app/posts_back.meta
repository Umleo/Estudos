{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/posts_back/layout,_N_T_/posts_back/page,_N_T_/posts_back"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/posts_back/__PAGE__",
    "/posts_back",
    "/_index",
    "/_head"
  ]
}